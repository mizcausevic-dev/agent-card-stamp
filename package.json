{
  "name": "agent-card-stamp",
  "version": "0.1.0",
  "description": "Build and validate a minimal A2A AgentCard per agent-cards-spec v0.1 from a StampOptions struct. Enforces id / version regex, enum constraints, and the spec's allOf clause (autonomy_level=autonomous requires safety_posture.incident_response_uri) with a clear error. Sibling of prompt-provenance-stamp.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "author": "mizcausevic-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/mizcausevic-dev/agent-card-stamp"
  },
  "keywords": [
    "a2a",
    "agent-cards",
    "agent-to-agent",
    "stamp",
    "scaffolding",
    "validation",
    "ai-governance",
    "kinetic-gain-suite",
    "typescript"
  ],
  "bin": {
    "agent-card-stamp": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "demo": "tsx src/cli.ts fixtures/research-assistant.json",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
